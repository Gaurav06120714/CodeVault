# CodeVault — PRODUCTION environment template.
# Copy to `.env` next to docker-compose.prod.yml (gitignored):  cp .env.production.example .env
# Every value below is interpolated into docker-compose.prod.yml at `docker compose up`.
# NEVER commit the filled-in .env — it holds live secrets.

# ─────────────────────────────────────────────────────────────────────────────
# 1. Public domain (required for Caddy's automatic HTTPS)
#    Point an A record for this domain at your server's public IP first.
# ─────────────────────────────────────────────────────────────────────────────
DOMAIN=codevault.example.com

# ─────────────────────────────────────────────────────────────────────────────
# 2. PostgreSQL — the primary datastore.
#    Used to build DATABASE_URL for both backends inside the compose network.
#    Use a long random password in production.
# ─────────────────────────────────────────────────────────────────────────────
DB_PASSWORD=change-me-to-a-long-random-string

# ─────────────────────────────────────────────────────────────────────────────
# 3. App secrets — MUST be identical across web-backend and git-service.
#    JWT_SECRET     : signs auth cookies/tokens.        (>= 32 random chars)
#    ENCRYPTION_KEY : encrypts stored platform session tokens. (EXACTLY 64 hex chars)
#    ⚠️  Back these up securely. Rotating ENCRYPTION_KEY makes all stored tokens
#        undecryptable — users would have to reconnect every platform.
#    Generate:
#      JWT_SECRET     ->  openssl rand -base64 48
#      ENCRYPTION_KEY ->  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-base64-48
ENCRYPTION_KEY=change-me-64-hex-chars-generate-with-openssl-rand-hex-32

# ─────────────────────────────────────────────────────────────────────────────
# 4. OAuth apps (create at each provider; set the callback/redirect URL to your DOMAIN).
#    GitHub  : https://github.com/settings/developers
#              Authorization callback URL -> https://<DOMAIN>/login/callback
#    Google  : https://console.cloud.google.com/apis/credentials
#              Authorized redirect URI    -> https://<DOMAIN>/login/callback/google
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ─────────────────────────────────────────────────────────────────────────────
# Notes
# - REDIS_URL / DATABASE_URL are NOT set here: docker-compose.prod.yml builds them
#   from the internal service names (redis://redis:6379, postgres://...@postgres:5432).
# - NEXT_PUBLIC_* values are passed as build args in the compose file and baked into
#   the frontend bundle at build time.
# - NODE_ENV is forced to "production" inside the compose file.
# ─────────────────────────────────────────────────────────────────────────────
