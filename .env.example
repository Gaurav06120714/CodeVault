# ---- Database ----
# Local SQLite for dev, or a Postgres URL for production
DATABASE_URL="file:./prisma/dev.db"

# ---- GitHub ----
# Personal access token / OAuth token used to push solutions to the user's repo
GITHUB_TOKEN=""
# Target repo where solutions are synced, e.g. "Gaurav06120714/LeetCodeQuestions"
GITHUB_SYNC_REPO=""

# ---- Platform connections (Path B: one-time authorized connect) ----
# LeetCode session values, provided once by the user to fetch their own code
LEETCODE_SESSION=""
LEETCODE_CSRF=""

# ---- App ----
SYNC_INTERVAL_MINUTES="180"
