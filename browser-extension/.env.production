# Production build (`npm run build`). Everything routes through the frontend same-origin proxy:
#   /api    → web-backend  (extension-token handoff, sent with the session cookie)
#   /gitapi → git-service  (submission ingest, sent with the Bearer JWT)
VITE_API_URL=https://codevault-ig6c.onrender.com/api
VITE_GIT_SERVICE_URL=https://codevault-ig6c.onrender.com/gitapi
VITE_WEB_APP_URL=https://codevault-ig6c.onrender.com
