# CodeVault mobile (Expo Go) — copy to `.env` and set your dev machine's LAN IP.
# The phone CANNOT reach the laptop's `localhost`, so use the LAN address
# printed by `ipconfig getifaddr en0` (macOS) or your Wi-Fi adapter's IP.
#
# Both services must be reachable from the phone on the same Wi-Fi network.
# web-backend also needs its CORS allowlist to include this origin.

EXPO_PUBLIC_WEB_API=http://172.20.10.2:4000/api
EXPO_PUBLIC_GIT_API=http://172.20.10.2:5050/api
