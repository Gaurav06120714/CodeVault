# CodeVault — Docker Compose environment template.
# Copy to `.env` in the repo root (gitignored): `cp .env.docker.example .env`
# These values are interpolated into docker-compose.yml for the data layer.
# Per-service app secrets (JWT, GitHub OAuth, encryption key) live in
# web-backend/.env and git-service/.env (see each service's .env.example).

# --- PostgreSQL (shared database) ---
POSTGRES_USER=codevault
POSTGRES_PASSWORD=codevault
POSTGRES_DB=codevault
POSTGRES_PORT=5432

# --- Redis (cache + rate-limit + BullMQ queue) ---
REDIS_PORT=6379

# --- Service host ports ---
WEB_BACKEND_PORT=4000
GIT_SERVICE_PORT=5000
